# Start PolicyKit authentication agent
exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
exec --no-startup-id dunst

exec --no-startup-id google-chrome
exec --no-startup-id brave-browser


assign [class="Google-chrome"] 2
assign [class="Brave-browser"] 1
assign [class="Netsoft-com.netsoft.hubstaff"] 10

gaps inner 5px

bindsym $mod+slash exec scrot -s ~/Pictures/screenshot_%Y-%m-%d_%H-%M-%S.png
bindsym $mod+o exec nautilus --new-window
bindsym $mod+Shift+p exec sudo shutdown now

bindsym $mod+p exec --no-startup-id rofi-rbw
